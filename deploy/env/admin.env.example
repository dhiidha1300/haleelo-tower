# ───────────────────────────────────────────────────────────────────────────
# Haleelo Tower Admin (Next.js) — production env template
# Copy to /var/www/haleelo/admin/.env.production BEFORE running `npm run build`.
# NEXT_PUBLIC_* vars are inlined at build time, so you MUST rebuild after any
# change here.
# ───────────────────────────────────────────────────────────────────────────

# Base URL of the Laravel API (no trailing slash).
NEXT_PUBLIC_API_URL=https://api.YOUR_DOMAIN
