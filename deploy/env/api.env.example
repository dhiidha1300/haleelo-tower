# ───────────────────────────────────────────────────────────────────────────
# Haleelo Tower API — production .env template
# Copy to /var/www/haleelo/api/.env, fill the blanks, then:
#   php artisan key:generate
#   php artisan config:cache
# Never commit the real .env.
# ───────────────────────────────────────────────────────────────────────────

APP_NAME="Haleelo Tower"
APP_ENV=production
APP_KEY=                       # generated by `php artisan key:generate`
APP_DEBUG=false
APP_URL=https://api.YOUR_DOMAIN

LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=haleelo
DB_USERNAME=haleelo
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Sessions / cache / queue ───────────────────────────────────────────────
# Pilot runs jobs inline (sync). Switch to "database" + run queue migration
# and the Supervisor worker when you want async processing.
QUEUE_CONNECTION=sync
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ── Sanctum / CORS ─────────────────────────────────────────────────────────
# The admin panel domain must be listed here for cookie auth to work.
SANCTUM_STATEFUL_DOMAINS=admin.YOUR_DOMAIN
SESSION_DOMAIN=.YOUR_DOMAIN
# Comma-separated production origins allowed to call the API (read by config/cors.php).
CORS_ALLOWED_ORIGINS=https://admin.YOUR_DOMAIN

# ── Filesystem ─────────────────────────────────────────────────────────────
# Uploaded documents/avatars use the "public" disk. Run once after deploy:
#   php artisan storage:link
FILESYSTEM_DISK=public

# ── Mail (Resend) ──────────────────────────────────────────────────────────
# Leave blank to disable email; jobs fail gracefully when unconfigured.
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS=no-reply@YOUR_DOMAIN
MAIL_FROM_NAME="Haleelo Tower"

# ── WhatsApp / OTP provider (Twilio) ───────────────────────────────────────
# Leave blank to disable; 2FA codes are still generated and visible in audit.
WHATSAPP_PROVIDER=twilio
WHATSAPP_ACCOUNT_SID=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_SENDER_NUMBER=
