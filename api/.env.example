APP_NAME="Haleelo Tower"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.halelotower.so
APP_TIMEZONE=Africa/Mogadishu

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=haleelo_tower
DB_USERNAME=haleelo_user
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS="noreply@halelotower.so"
MAIL_FROM_NAME="Haleelo Tower"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=haleelo-tower
AWS_URL=

RESEND_API_KEY=

WHATSAPP_PROVIDER=twilio
WHATSAPP_ACCOUNT_SID=
WHATSAPP_AUTH_TOKEN=
WHATSAPP_SENDER_NUMBER=

SANCTUM_STATEFUL_DOMAINS=halelotower.so,portal.halelotower.so,admin.halelotower.so,localhost,127.0.0.1
SANCTUM_GUARDS=web

SESSION_DOMAIN=.halelotower.so
SESSION_SECURE_COOKIES=true

VITE_API_URL=https://api.halelotower.so

# 2FA Configuration
TWO_FACTOR_OTP_LENGTH=6
TWO_FACTOR_OTP_TIMEOUT=300

# System Configuration
INVOICE_DUE_DAYS=7
WORKING_HOURS_PER_DAY=8
WORKING_DAYS_PER_MONTH=26
